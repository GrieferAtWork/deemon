import deemon;
import * from ctypes;
import .common.test;

function genericAlignOf(T: CType): deemon.int {
	struct st {
		("_", char),
		("v", T),
	};
	return st.offsetof("v");
}

/* Assert that the good 'ol native-c-alignment trick also works with ctypes */
for (local T: [uint8_t, uint16_t, uint32_t, uint64_t, uint128_t])
	test.assertEquals(T.alignof, genericAlignOf(T));


struct MyComplexStruct {
	("x", int32_t),
	("y", int32_t),
	union {
		("zle", le32),
		("zbe", be32),
	},
	("v", uint32_t[13]),
	union {
		("kp", char.ptr),
		("ku64", uint64_t),
	},
};



test.assertEquals(0, MyComplexStruct.offsetof("x"));
test.assertEquals(4, MyComplexStruct.offsetof("y"));
test.assertEquals(8, MyComplexStruct.offsetof("zle"));
test.assertEquals(8, MyComplexStruct.offsetof("zbe"));
test.assertEquals(12, MyComplexStruct.offsetof("v"));
test.assertEquals(64, MyComplexStruct.offsetof("kp"));
test.assertEquals(64, MyComplexStruct.offsetof("ku64"));

test.assertEquals(4, MyComplexStruct.offsetafter("x"));
test.assertEquals(8, MyComplexStruct.offsetafter("y"));
test.assertEquals(12, MyComplexStruct.offsetafter("zle"));
test.assertEquals(12, MyComplexStruct.offsetafter("zbe"));
test.assertEquals(64, MyComplexStruct.offsetafter("v"));
test.assertEquals(64 + Pointer.sizeof, MyComplexStruct.offsetafter("kp"));
test.assertEquals(72, MyComplexStruct.offsetafter("ku64"));

test.assertEquals(uint64_t.alignof, MyComplexStruct.alignof);
test.assertEquals(72, MyComplexStruct.sizeof);

/* Assert that all types of initialization work for "MyComplexStruct" */
test.assertEqualsTyped(
	MyComplexStruct(),
	MyComplexStruct({}),
);
test.assertEqualsTyped(
	MyComplexStruct(x: 10, y: 20, zle: 0x11223344, v: { 1, 2, 3, 4 }),
	MyComplexStruct({ 10, 20, { 0x11223344 }, { 1, 2, 3, 4 }, { none } }),
);
local myString = "foobar";
test.assertEqualsTyped(
	MyComplexStruct(x: 10, y: 20, zle: 0x11223344, v: { 1, 2, 3, 4 }, kp:	 myString),
	MyComplexStruct({ .x = 10, .y = 20, .zle = 0x11223344, .v = { 1, 2, 3, 4 }, .kp = myString }),
);



/* Also assert that string-to-char-pointer always works */
union MyStringUnion {
	("s", char.ptr),
	("c16", char16_t.ptr),
	("c32", char32_t.ptr),
	("u8_16", uint8_t[16].ptr),
	("u8_8", uint8_t[8].ptr),
	("u8_4", uint8_t[4].ptr),
	("u16_16", uint16_t[16].ptr),
	("u16_8", uint16_t[8].ptr),
	("u16_4", uint16_t[4].ptr),
	("u32_4", uint32_t[4].ptr),
	("ws", wchar_t.ptr),
	("wc_4", wchar_t[4].ptr),
};

local x = MyStringUnion();
x.s = "foo";
test.assertSequence(x.u8_4.ind, "foo\0".ordinals);

x.c16 = "foo";
test.assertSequence(x.u16_4.ind, "foo\0".ordinals);
if (BYTE_ORDER == ORDER_LITTLE_ENDIAN) {
	test.assertSequence(x.u8_8.ind, "f\0o\0o\0\0\0".ordinals);
} else {
	test.assertSequence(x.u8_8.ind, "\0f\0o\0o\0\0".ordinals);
}

x.c32 = "foo";
test.assertSequence(x.u32_4.ind, "foo\0".ordinals);
if (BYTE_ORDER == ORDER_LITTLE_ENDIAN) {
	test.assertSequence(x.u16_8.ind, "f\0o\0o\0\0\0".ordinals);
	test.assertSequence(x.u8_16.ind, "f\0\0\0o\0\0\0o\0\0\0\0\0\0\0".ordinals);
} else {
	test.assertSequence(x.u16_8.ind, "\0f\0o\0o\0\0".ordinals);
	test.assertSequence(x.u8_16.ind, "\0\0\0f\0\0\0o\0\0\0o\0\0\0\0".ordinals);
}

x.ws = "foo";
test.assertSequence(x.wc_4.ind, "foo\0".ordinals);
