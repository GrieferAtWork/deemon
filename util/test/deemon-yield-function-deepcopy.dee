import * from deemon;
import .common.test;

@[copyable]
function foo(a, b = 30) {
	yield a;
	yield b;
}

local c0 = foo(10, 20);
local c1 = foo(11, b: 21);
local c2 = foo(a: 12, b: 22);
local c3 = foo(13);
local c4 = foo(a: 14);

#if 1 // TODO: "Cannot serialize instance of `_YieldFunctionIterator'"
#define assertSequence assertEquals
#endif

test.assertSequence(c0, {10,20});
test.assertSequence(c1, {11,21});
test.assertSequence(c2, {12,22});
test.assertSequence(c3, {13,30});
test.assertSequence(c4, {14,30});

test.assertSequence(deepcopy c0, {10,20});
test.assertSequence(deepcopy c1, {11,21});
test.assertSequence(deepcopy c2, {12,22});
test.assertSequence(deepcopy c3, {13,30});
test.assertSequence(deepcopy c4, {14,30});

