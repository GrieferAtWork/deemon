@@Number of times `TrackedClass.~this()` was called
global Tracked_destructorCalled = 0;
class TrackedClass {
	~this() {
		++Tracked_destructorCalled;
	}
}

@@Number of times `SelfRevivingClass.~this()` was called
global SelfReviving_destructorCalls = 0;
global SelfReviving_instance;
class SelfRevivingClass {
	private member myRef: TrackedClass;
	this()
		: myRef(TrackedClass())
	{}

	~this() {
		SelfReviving_instance = this;
		++SelfReviving_destructorCalls;
	}
}


assert SelfReviving_instance !is bound;
assert SelfReviving_destructorCalls == 0;
assert Tracked_destructorCalled == 0;

/* Since the SelfReviving_instance isn't stored anywhere, the
 * user-defined destructor is called instantly. */
SelfRevivingClass();

/* Our custom destructor should have revived the object */
assert SelfReviving_instance is bound;
assert Tracked_destructorCalled == 0;
assert SelfReviving_destructorCalls == 1;

/* Unbind the SelfReviving_instance here... */
del(SelfReviving_instance);

/* ... but since user-defined destructors are only called **once**,
 * the object should now have been destroyed (without its destructor
 * being invoked) -- we can track this happened by taking a look at
 * `Tracked_destructorCalled`, which is incremented when its destructor
 * is called, which happens when "SelfRevivingClass" is destroyed for
 * real (without having the user-defined destructor invoked) */
assert SelfReviving_instance !is bound;
assert Tracked_destructorCalled == 1;
assert SelfReviving_destructorCalls == 1;
