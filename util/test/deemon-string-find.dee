import * from errors;
import .common.test;

#define TRY(x) (try x catch (e...) e)


function t(x, w) {
	assert w("xxx") !in x;
	assert x.find(w("xxx")) == -1;
	assert x.rfind(w("xxx")) == -1;
	assert (try x.index(w("xxx")) catch (e...) e) is ItemNotFound;
	assert (try x.rindex(w("xxx")) catch (e...) e) is ItemNotFound;
	for (local op: { "find", "index" }) {
		local rop = f"r{op}";
		assert x.operator . (op)(x) == 0;
//		assert x.operator . (op)({x}.some) == 0; // TODO
		assert x.operator . (op + "any")({x}) == 0;
		assert x.operator . (op)(w("a")) == 0;
		assert x.operator . (op)(w("b")) == 1;
		assert x.operator . (op)(w("c")) == 2;
		assert x.operator . (op)(w("d")) == 3;
		assert x.operator . (op)(w("ab")) == 0;
		assert x.operator . (op)(w("bc")) == 1;
		assert x.operator . (op)(w("cd")) == 2;
		assert x.operator . (op)(w("abc")) == 0;
		assert x.operator . (op)(w("bcd")) == 1;
		assert x.operator . (op)(w("abcd")) == 0;
		assert x.operator . (rop)(x) == 0;
//		assert x.operator . (rop)({x}.some) == 0; // TODO
		assert x.operator . (rop + "any")({x}) == 0;
		assert x.operator . (rop)(w("d")) == 3;
		assert x.operator . (rop)(w("c")) == 2;
		assert x.operator . (rop)(w("b")) == 1;
		assert x.operator . (rop)(w("a")) == 0;
		assert x.operator . (rop)(w("ab")) == 0;
		assert x.operator . (rop)(w("bc")) == 1;
		assert x.operator . (rop)(w("cd")) == 2;
		assert x.operator . (rop)(w("abc")) == 0;
		assert x.operator . (rop)(w("bcd")) == 1;
		assert x.operator . (rop)(w("abcd")) == 0;
	}
	for (local xOP, wOP: {
		(x -> x, w),
		(x -> x.lower(), w),
		(x -> x.upper(), w),
		(x -> x, x -> w(x).lower()),
		(x -> x.lower(), x -> w(x).lower()),
		(x -> x.upper(), x -> w(x).lower()),
		(x -> x, x -> w(x).upper()),
		(x -> x.lower(), x -> w(x).upper()),
		(x -> x.upper(), x -> w(x).upper()),
	}) {
		for (local baseOp: { "find", "index" }) {
			local op = f"case{baseOp}";
			local rop = f"caser{baseOp}";
			assert xOP(x).operator . (op)(wOP(x)) == (0, #x);
//			assert xOP(x).operator . (op)({wOP(x)}.some) == (0, #x); // TODO
			assert xOP(x).operator . (op + "any")({wOP(x)}) == (0, #x);
			assert xOP(x).operator . (op)(wOP("a")) == (0, 1);
			assert xOP(x).operator . (op)(wOP("b")) == (1, 2);
			assert xOP(x).operator . (op)(wOP("c")) == (2, 3);
			assert xOP(x).operator . (op)(wOP("d")) == (3, 4);
			assert xOP(x).operator . (op)(wOP("ab")) == (0, 2);
			assert xOP(x).operator . (op)(wOP("bc")) == (1, 3);
			assert xOP(x).operator . (op)(wOP("cd")) == (2, 4);
			assert xOP(x).operator . (op)(wOP("abc")) == (0, 3);
			assert xOP(x).operator . (op)(wOP("bcd")) == (1, 4);
			assert xOP(x).operator . (op)(wOP("abcd")) == (0, 4);
			assert xOP(x).operator . (rop)(wOP(x)) == (0, #x);
//			assert xOP(x).operator . (rop)({wOP(x)}.some) == (0, #x); // TODO
			assert xOP(x).operator . (rop + "any")({wOP(x)}) == (0, #x);
			assert xOP(x).operator . (rop)(wOP("d")) == (3, 4);
			assert xOP(x).operator . (rop)(wOP("c")) == (2, 3);
			assert xOP(x).operator . (rop)(wOP("b")) == (1, 2);
			assert xOP(x).operator . (rop)(wOP("a")) == (0, 1);
			assert xOP(x).operator . (rop)(wOP("ab")) == (0, 2);
			assert xOP(x).operator . (rop)(wOP("bc")) == (1, 3);
			assert xOP(x).operator . (rop)(wOP("cd")) == (2, 4);
			assert xOP(x).operator . (rop)(wOP("abc")) == (0, 3);
			assert xOP(x).operator . (rop)(wOP("bcd")) == (1, 4);
			assert xOP(x).operator . (rop)(wOP("abcd")) == (0, 4);
		}
	}
	function assertCount(needle, n) {
		assert x.count(needle) == n;
		assert x.contains(needle) == (n != 0);
		for (local xv: { x, x.lower(), x.upper() }) {
			assert xv.casecount(needle) == n, f"{repr xv}.casecount({repr needle}) == {repr n}";
			assert xv.casecount(needle.lower()) == n;
			assert xv.casecount(needle.upper()) == n;
			assert xv.casecontains(needle) == (n != 0);
			assert xv.casecontains(needle.lower()) == (n != 0);
			assert xv.casecontains(needle.upper()) == (n != 0);
		}
	}
	assertCount("a", 1);
	assertCount("ab", 1);
	assertCount("abcd", 1);
	assertCount("cd", 1);
	assertCount("d", 1);
	assertCount("bc", 1);
	assertCount("cb", 0);
	assert x.partition(w("xxx"))[0] === x;
	assert x.partition(w("xxx"))[1] == "";
	assert x.partition(w("xxx"))[2] == "";
	assert x.rpartition(w("xxx"))[0] == "";
	assert x.rpartition(w("xxx"))[1] == "";
	assert x.rpartition(w("xxx"))[2] === x;
	assert x.casepartition(w("xxx"))[0] === x;
	assert x.casepartition(w("xxx"))[1] == "";
	assert x.casepartition(w("xxx"))[2] == "";
	assert x.caserpartition(w("xxx"))[0] == "";
	assert x.caserpartition(w("xxx"))[1] == "";
	assert x.caserpartition(w("xxx"))[2] === x;
	test.assertSequence(x.split(w("xxx")), { x });
	test.assertSequence(x.casesplit(w("xxx")), { x });
	test.assertSequence(x.findall(w("xxx")), { });
	test.assertSequence(x.casefindall(w("xxx")), { });
	assert x.split(w("xxx")) == { x };
	assert x.casesplit(w("xxx")) == { x };
	assert x.findall(w("xxx")) == { };
	assert x.casefindall(w("xxx")) == { };
}

t("abcd", x -> x);
t("abcd\U00001234", x -> x); /* Test 16-bit code paths */
t("abcd\U12345678", x -> x); /* Test 32-bit code paths */

/* string function cannot be used with Bytes arguments, since
 * raw Bytes cannot be implicitly converted into strings (since
 * their encoding is unknown) */
//t("abcd", x -> x.bytes());
t("abcd".bytes(), x -> x);
t("abcd".bytes(), x -> x.bytes());


global BASE_BLOB = "Line1\nDATA\n{FOO}\nLine4\nend";

for (local blob: {
	BASE_BLOB,
	BASE_BLOB.bytes(),
	BASE_BLOB + "\U0000FFFF",
	BASE_BLOB + "\UFFFFFFFF",
}) {
	test.assertEqualsTyped(blob.findany({"ine", "nd"}), 1);
	test.assertEqualsTyped(blob.rfindany({"ine", "nd"}), 24);
	test.assertEqualsTyped(blob.indexany({"ine", "nd"}), 1);
	test.assertEqualsTyped(blob.rindexany({"ine", "nd"}), 24);
	test.assertSequence(blob.casefindany({"ine", "nd"}), {1,4});
	test.assertSequence(blob.caserfindany({"ine", "nd"}), {24,26});
	test.assertSequence(blob.caseindexany({"ine", "nd"}), {1,4});
	test.assertSequence(blob.caserindexany({"ine", "nd"}), {24,26});

	test.assertEqualsTyped(blob.findany({"INE", "ND"}), -1);
	test.assertEqualsTyped(blob.rfindany({"INE", "ND"}), -1);
	assert TRY(blob.indexany({"INE", "ND"})) is ItemNotFound;
	assert TRY(blob.rindexany({"INE", "ND"})) is ItemNotFound;
	test.assertSequence(blob.casefindany({"INE", "ND"}), {1,4});
	test.assertSequence(blob.caserfindany({"INE", "ND"}), {24,26});
	test.assertSequence(blob.caseindexany({"INE", "ND"}), {1,4});
	test.assertSequence(blob.caserindexany({"INE", "ND"}), {24,26});

	function doFind(what, args...) {
		local result = blob.find(what, args...);
		test.assertEqualsTyped(result, blob.findany({what}, args...));
		test.assertEqualsTyped(result, try blob.index(what, args...) catch (ItemNotFound) -1);
		test.assertEqualsTyped(result, try blob.indexany({what}, args...) catch (ItemNotFound) -1);
		return result;
	}

	function doRFind(what, args...) {
		local result = blob.rfind(what, args...);
		test.assertEqualsTyped(result, blob.rfindany({what}, args...));
		test.assertEqualsTyped(result, try blob.rindex(what, args...) catch (ItemNotFound) -1);
		test.assertEqualsTyped(result, try blob.rindexany({what}, args...) catch (ItemNotFound) -1);
		return result;
	}

	function doCaseFind(what, args...) {
		local result = blob.casefind(what, args...);
		test.assertEqualsTyped(result, blob.casefindany({what}, args...));
		test.assertEqualsTyped(result, try blob.caseindex(what, args...) catch (ItemNotFound) none);
		test.assertEqualsTyped(result, try blob.caseindexany({what}, args...) catch (ItemNotFound) none);
		return result;
	}

	function doCaseRFind(what, args...) {
		local result = blob.caserfind(what, args...);
		test.assertEqualsTyped(result, blob.caserfindany({what}, args...));
		test.assertEqualsTyped(result, try blob.caserindex(what, args...) catch (ItemNotFound) none);
		test.assertEqualsTyped(result, try blob.caserindexany({what}, args...) catch (ItemNotFound) none);
		return result;
	}

	test.assertEqualsTyped(doFind("Line1"), 0);
	test.assertEqualsTyped(doRFind("Line1"), 0);
	test.assertSequence(doCaseFind("Line1"), {0,5});
	test.assertSequence(doCaseRFind("Line1"), {0,5});

	test.assertEqualsTyped(doFind("line1"), -1);
	test.assertEqualsTyped(doRFind("line1"), -1);
	test.assertSequence(doCaseFind("line1"), {0,5});
	test.assertSequence(doCaseRFind("line1"), {0,5});

	test.assertEqualsTyped(doFind("Line1", 3), -1);
	test.assertEqualsTyped(doRFind("Line1", 3), -1);
	test.assertNone(doCaseFind("Line1", 3));
	test.assertNone(doCaseRFind("Line1", 3));

	test.assertEqualsTyped(doFind("Line"), 0);
	test.assertEqualsTyped(doRFind("Line"), 17);
	test.assertSequence(doCaseFind("line"), {0,4});
	test.assertSequence(doCaseRFind("line"), {17,21});

	test.assertEqualsTyped(doFind("Line", 3), 17);
	test.assertEqualsTyped(doRFind("Line", 3), 17);
	test.assertSequence(doCaseFind("line", 3), {17,21});
	test.assertSequence(doCaseRFind("line", 3), {17,21});

	test.assertEqualsTyped(doFind("Line", 3, 21), 17);
	test.assertEqualsTyped(doRFind("Line", 3, 21), 17);
	test.assertSequence(doCaseFind("line", 3, 21), {17,21});
	test.assertSequence(doCaseRFind("line", 3, 21), {17,21});

	test.assertEqualsTyped(doFind("Line", 3, 20), -1);
	test.assertEqualsTyped(doRFind("Line", 3, 20), -1);
	test.assertNone(doCaseFind("line", 3, 20));
	test.assertNone(doCaseRFind("line", 3, 20));

	test.assertEqualsTyped(doFind("Line", 0, 21), 0);
	test.assertEqualsTyped(doRFind("Line", 0, 21), 17);
	test.assertSequence(doCaseFind("line", 0, 21), {0,4});
	test.assertSequence(doCaseRFind("line", 0, 21), {17,21});

	test.assertEqualsTyped(doFind("Line", 0, 20), 0);
	test.assertEqualsTyped(doRFind("Line", 0, 20), 0);
	test.assertSequence(doCaseFind("line", 0, 20), {0,4});
	test.assertSequence(doCaseRFind("line", 0, 20), {0,4});

	assert blob.startswith("Line1");
	assert blob.casestartswith("Line1");
	assert !blob.startswith("line1");
	assert blob.casestartswith("line1");

	assert blob.startswith("Line1", 0, 99);
	assert blob.casestartswith("Line1", 0, 99);
	assert !blob.startswith("line1", 0, 99);
	assert blob.casestartswith("line1", 0, 99);

	assert !blob.startswith("Line1", 1, 99);
	assert !blob.casestartswith("Line1", 1, 99);
	assert !blob.startswith("line1", 1, 99);
	assert !blob.casestartswith("line1", 1, 99);

	assert blob.startswith("ine1", 1, 99);
	assert blob.casestartswith("ine1", 1, 99);
	assert !blob.startswith("INE1", 1, 99);
	assert blob.casestartswith("INE1", 1, 99);

	assert !blob.startswith("ine1", 1, 4);
	assert !blob.casestartswith("ine1", 1, 4);
	assert !blob.startswith("INE1", 1, 4);
	assert !blob.casestartswith("INE1", 1, 4);

	assert blob.startswith("ine1", 1, 5);
	assert blob.casestartswith("ine1", 1, 5);
	assert !blob.startswith("INE1", 1, 5);
	assert blob.casestartswith("INE1", 1, 5);

	local eBlob = blob;
	local base = 0;
	if (blob.last in "\U0000FFFF\UFFFFFFFF") {
		eBlob = blob.last + blob[:-1];
		base = 1;
	}

	assert eBlob.endswith("\nend");
	assert eBlob.caseendswith("\nend");
	assert !eBlob.endswith("\nEND");
	assert eBlob.caseendswith("\nEND");

	assert eBlob.endswith("\nend", base + 22);
	assert eBlob.caseendswith("\nend", base + 22);
	assert !eBlob.endswith("\nEND", base + 22);
	assert eBlob.caseendswith("\nEND", base + 22);

	assert eBlob.endswith("\nend", base + 22, base + 26);
	assert eBlob.caseendswith("\nend", base + 22, base + 26);
	assert !eBlob.endswith("\nEND", base + 22, base + 26);
	assert eBlob.caseendswith("\nEND", base + 22, base + 26);

	assert eBlob.endswith("\nend", 0, base + 26);
	assert eBlob.caseendswith("\nend", 0, base + 26);
	assert !eBlob.endswith("\nEND", 0, base + 26);
	assert eBlob.caseendswith("\nEND", 0, base + 26);

	assert !eBlob.endswith("\nend", 0, base + 25);
	assert !eBlob.caseendswith("\nend", 0, base + 25);
	assert !eBlob.endswith("\nEND", 0, base + 25);
	assert !eBlob.caseendswith("\nEND", 0, base + 25);

	assert eBlob.endswith("\nen", 0, base + 25);
	assert eBlob.caseendswith("\nen", 0, base + 25);
	assert !eBlob.endswith("\nEN", 0, base + 25);
	assert eBlob.caseendswith("\nEN", 0, base + 25);
}

