import .common.test;

local iconv = try import("iconv") catch (...) none;
if (iconv is none)
	return;


test.assertEqualsTyped(
	iconv.encode("Hello World", "base64"),
	"SGVsbG8gV29ybGQ=".bytes()
);
test.assertEqualsTyped(
	iconv.decode("SGVsbG8gV29ybGQ=", "base64"),
	"Hello World"
);
test.assertEqualsTyped(
	iconv.transcode("SGVsbG8gV29ybGQ=", "base64", "utf-8-bom"),
	"\xEF\xBB\xBFHello World".bytes()
);


test.assertEqualsTyped(
	iconv.encode("/var/foo?x=49&z=2", "uri"),
	"%2Fvar%2Ffoo%3Fx%3D49%26z%3D2".bytes()
);
test.assertEqualsTyped(
	iconv.decode("%2Fvar%2Ffoo%3Fx%3D49%26z%3D2", "uri"),
	"/var/foo?x=49&z=2"
);
