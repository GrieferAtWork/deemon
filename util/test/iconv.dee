import * from deemon;
import .common.test;

local iconv = try import("iconv") catch (...) none;
if (iconv is none)
	return;

function assertEncode(data: string, codec: string, result: Bytes) {
	/* Encode using convenience wrapper */
	test.assertEqualsTyped(iconv.encode(data, codec), result);

	/* Encode using "iconv.Encoder" */
	local w = File.Writer(hint: "bytes");
	with (local d = iconv.Encoder(codec, out: w))
		print d: data,;
	test.assertEqualsTyped(result, w.bytes);

	/* Decode using convenience wrapper */
	test.assertEqualsTyped(iconv.decode(result, codec), data);

	/* Decode using "iconv.Decoder" */
	local w = File.Writer(hint: "string");
	with (local d = iconv.Decoder(codec, out: w))
		d.write(result);
	test.assertEqualsTyped(data, w.string);
}

function assertTranscode(data: Bytes, incodec: string, outcodec: string, result: Bytes) {
	/* Transcode using convenience wrapper */
	test.assertEqualsTyped(iconv.transcode(data, incodec, outcodec), result);
	test.assertEqualsTyped(iconv.transcode(result, outcodec, incodec), data);

	/* Transcode using "iconv.Transcoder" */
	local w = File.Writer(hint: "bytes");
	with (local d = iconv.Transcoder(incodec, outcodec, out: w))
		d.write(data);
	test.assertEqualsTyped(result, w.bytes);

	local w = File.Writer(hint: "bytes");
	with (local d = iconv.Transcoder(outcodec, incodec, out: w))
		d.write(result);
	test.assertEqualsTyped(data, w.bytes);
}


assertEncode("Hello World", "base64", "SGVsbG8gV29ybGQ=".bytes());
assertEncode("/var/foo?x=49&z=2", "uri", "%2Fvar%2Ffoo%3Fx%3D49%26z%3D2".bytes());
assertEncode("¥ƒ§", "csAdobeStandardEncoding", "\xA5\xA6\xA7".bytes());

assertTranscode(
	"SGVsbG8gV29ybGQ=".bytes(),
	"base64", "utf-8-bom",
	"\xEF\xBB\xBFHello World".bytes()
);

test.assertEqualsTyped(iconv.decode(
	/* Intentional: trailing ";" is missing for first "&amp"
	 * (some legacy XML entities have optional trailing ";") */
	"&lt;&amp∳&amp;&gt; = &CounterClockwiseContourIntegral;".encode("utf-8"),
	"xml"
), "<&∳&> = ∳");

