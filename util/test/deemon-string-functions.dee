import * from deemon;
import * from errors;
import .common.test;

#define TRY(x) (try x catch (e...) e)

#if 0
#define TEST1(expected, actual, ...) \
	try { \
		test.assertEquals(expected, actual.__VA_ARGS__); \
		test.assertEquals(expected.bytes(), actual.bytes().__VA_ARGS__); \
	} catch (...) { \
		print(__FILE__, "(", __LINE__, ") : HERE"); \
		throw; \
	}
#else
#define TEST1(expected, actual, ...) \
	test.assertEquals(expected, actual.__VA_ARGS__); \
	test.assertEquals(expected.bytes(), actual.bytes().__VA_ARGS__)
#endif
#define V_TEST1(expected, actual, ...) \
	test.assertEquals(expected, actual.__VA_ARGS__); \
	test.assertEquals(expected, actual.bytes().__VA_ARGS__)
#define TEST2(expected, actual, ...) test.assertEquals(expected, actual.__VA_ARGS__)
#define TEST4(expected, actual, ...) test.assertEquals(expected, actual.__VA_ARGS__)

/* reversed */
TEST1("a\U000000FFbcdef", "fedcb\U000000FFa", reversed());
TEST2("a\U0000FFFFbcdef", "fedcb\U0000FFFFa", reversed());
TEST4("a\UFFFFFFFFbcdef", "fedcb\UFFFFFFFFa", reversed());

TEST1("", "fedcb\U000000FFa", reversed(0, 0));
TEST2("", "fedcb\U0000FFFFa", reversed(0, 0));
TEST4("", "fedcb\UFFFFFFFFa", reversed(0, 0));

TEST1("f", "fedcb\U000000FFa", reversed(0, 1));
TEST2("f", "fedcb\U0000FFFFa", reversed(0, 1));
TEST4("f", "fedcb\UFFFFFFFFa", reversed(0, 1));

TEST1("\U000000FF", "fedcb\U000000FFa", reversed(5, 6));
TEST2("\U0000FFFF", "fedcb\U0000FFFFa", reversed(5, 6));
TEST4("\UFFFFFFFF", "fedcb\UFFFFFFFFa", reversed(5, 6));

/* expandtabs */
TEST1("a   b\na\U000000FFc d", "a\tb\na\U000000FFc\td", expandtabs(4));
TEST2("a   b\na\U0000FFFFc d", "a\tb\na\U0000FFFFc\td", expandtabs(4));
TEST4("a   b\na\UFFFFFFFFc d", "a\tb\na\UFFFFFFFFc\td", expandtabs(4));

/* unifylines */
TEST1("a\nb\n\U000000FF\nd", "a\nb\r\U000000FF\r\nd", unifylines());
TEST2("a\nb\n\U0000FFFF\nd", "a\nb\r\U0000FFFF\r\nd", unifylines());
TEST4("a\nb\n\UFFFFFFFF\nd", "a\nb\r\UFFFFFFFF\r\nd", unifylines());

TEST1("a<br>b<br>\U000000FF<br>d", "a\nb\r\U000000FF\r\nd", unifylines("<br>"));
TEST2("a<br>b<br>\U0000FFFF<br>d", "a\nb\r\U0000FFFF\r\nd", unifylines("<br>"));
TEST4("a<br>b<br>\UFFFFFFFF<br>d", "a\nb\r\UFFFFFFFF\r\nd", unifylines("<br>"));

/* indent */
TEST1("a\nb\r\U000000FF\r\nd", "a\nb\r\U000000FF\r\nd", indent(""));
TEST1("", "", indent("HEAD"));
TEST1("HEADa\nHEADb\rHEAD\U000000FF\r\nHEADd", "a\nb\r\U000000FF\r\nd", indent("HEAD"));
TEST2("HEADa\nHEADb\rHEAD\U0000FFFF\r\nHEADd", "a\nb\r\U0000FFFF\r\nd", indent("HEAD"));
TEST4("HEADa\nHEADb\rHEAD\UFFFFFFFF\r\nHEADd", "a\nb\r\UFFFFFFFF\r\nd", indent("HEAD"));


/* dedent */
TEST1("a\nb\r\U000000FF\r\nd", "HEADa\nHEADb\rHEAD\U000000FF\r\nHEADd", dedent(999, "HEAD"));
TEST2("a\nb\r\U0000FFFF\r\nd", "HEADa\nHEADb\rHEAD\U0000FFFF\r\nHEADd", dedent(999, "HEAD"));
TEST4("a\nb\r\UFFFFFFFF\r\nd", "HEADa\nHEADb\rHEAD\UFFFFFFFF\r\nHEADd", dedent(999, "HEAD"));

TEST1("Da\nDb\rD\U000000FF\r\nDd", "HEADa\nHEADb\rHEAD\U000000FF\r\nHEADd", dedent(3, "HEAD"));
TEST2("Da\nDb\rD\U0000FFFF\r\nDd", "HEADa\nHEADb\rHEAD\U0000FFFF\r\nHEADd", dedent(3, "HEAD"));
TEST4("Da\nDb\rD\UFFFFFFFF\r\nDd", "HEADa\nHEADb\rHEAD\UFFFFFFFF\r\nHEADd", dedent(3, "HEAD"));

TEST1("a\nb\r\U000000FF\r\nd", "    a\n    b\r    \U000000FF\r\n    d", dedent(999));
TEST2("a\nb\r\U0000FFFF\r\nd", "    a\n    b\r    \U0000FFFF\r\n    d", dedent(999));
TEST4("a\nb\r\UFFFFFFFF\r\nd", "    a\n    b\r    \UFFFFFFFF\r\n    d", dedent(999));

TEST1("a\nb\r\U000000FF\r\nd", "    a\n    b\r    \U000000FF\r\n    d", dedent(4));
TEST2("a\nb\r\U0000FFFF\r\nd", "    a\n    b\r    \U0000FFFF\r\n    d", dedent(4));
TEST4("a\nb\r\UFFFFFFFF\r\nd", "    a\n    b\r    \UFFFFFFFF\r\n    d", dedent(4));

TEST1(" a\n b\r \U000000FF\r\n d", "    a\n    b\r    \U000000FF\r\n    d", dedent(3));
TEST2(" a\n b\r \U0000FFFF\r\n d", "    a\n    b\r    \U0000FFFF\r\n    d", dedent(3));
TEST4(" a\n b\r \UFFFFFFFF\r\n d", "    a\n    b\r    \UFFFFFFFF\r\n    d", dedent(3));


/* replace */
TEST1("XaX\tb\nXaX\U000000FFc\td", "a\tb\na\U000000FFc\td", replace("a", "XaX"));
TEST2("XaX\tb\nXaX\U0000FFFFc\td", "a\tb\na\U0000FFFFc\td", replace("a", "XaX"));
TEST4("XaX\tb\nXaX\UFFFFFFFFc\td", "a\tb\na\UFFFFFFFFc\td", replace("a", "XaX"));

TEST1("XaX\tb\na\U000000FFc\td", "a\tb\na\U000000FFc\td", replace("a", "XaX", 1));
TEST2("XaX\tb\na\U0000FFFFc\td", "a\tb\na\U0000FFFFc\td", replace("a", "XaX", 1));
TEST4("XaX\tb\na\UFFFFFFFFc\td", "a\tb\na\UFFFFFFFFc\td", replace("a", "XaX", 1));

TEST1("a\tb\na\U000000FFc\td", "a\tb\na\U000000FFc\td", replace("", "XaX"));
TEST2("a\tb\na\U0000FFFFc\td", "a\tb\na\U0000FFFFc\td", replace("", "XaX"));
TEST4("a\tb\na\UFFFFFFFFc\td", "a\tb\na\UFFFFFFFFc\td", replace("", "XaX"));

TEST1("XaX", "", replace("", "XaX"));

TEST1("\U000000FF", "\U000000FF", replace("FF", "XaX"));
TEST2("\U0000FFFF", "\U0000FFFF", replace("FF", "XaX"));
TEST4("\UFFFFFFFF", "\UFFFFFFFF", replace("FF", "XaX"));


/* casereplace */
TEST1("XaX\tb\nXaX\U000000FFc\td", "a\tb\nA\U000000FFc\td", casereplace("a", "XaX"));
TEST2("XaX\tb\nXaX\U0000FFFFc\td", "a\tb\nA\U0000FFFFc\td", casereplace("a", "XaX"));
TEST4("XaX\tb\nXaX\UFFFFFFFFc\td", "a\tb\nA\UFFFFFFFFc\td", casereplace("a", "XaX"));

TEST1("XaX\tb\nA\U000000FFc\td", "a\tb\nA\U000000FFc\td", casereplace("a", "XaX", 1));
TEST2("XaX\tb\nA\U0000FFFFc\td", "a\tb\nA\U0000FFFFc\td", casereplace("a", "XaX", 1));
TEST4("XaX\tb\nA\UFFFFFFFFc\td", "a\tb\nA\UFFFFFFFFc\td", casereplace("a", "XaX", 1));

TEST1("a\tb\na\U000000FFc\td", "a\tb\na\U000000FFc\td", casereplace("", "XaX"));
TEST2("a\tb\na\U0000FFFFc\td", "a\tb\na\U0000FFFFc\td", casereplace("", "XaX"));
TEST4("a\tb\na\UFFFFFFFFc\td", "a\tb\na\UFFFFFFFFc\td", casereplace("", "XaX"));

TEST1("XaX", "", casereplace("", "XaX"));

TEST1("\U000000FF", "\U000000FF", casereplace("FF", "XaX"));
TEST2("\U0000FFFF", "\U0000FFFF", casereplace("FF", "XaX"));
TEST4("\UFFFFFFFF", "\UFFFFFFFF", casereplace("FF", "XaX"));

/* ord */
V_TEST1(0x000000FF, "\U000000FF", ord());
TEST2(0x0000FFFF, "\U0000FFFF", ord());
TEST4(0xFFFFFFFF, "\UFFFFFFFF", ord());

V_TEST1(0x000000FF, "a\U000000FFc", ord(1));
TEST2(0x0000FFFF, "a\U0000FFFFc", ord(1));
TEST4(0xFFFFFFFF, "a\UFFFFFFFFc", ord(1));

local s = "foo";
test.assertEquals(IndexError(seq: s, index: 6, length: 3), TRY(s.ord(6)));


/* casefold */
test.assertEquals("x\xDF\xFF".bytes(), "X\xDF\U000000FF".bytes().casefold());
test.assertEquals("xss\U000000FF", "X\xDF\U000000FF".casefold());
test.assertEquals("xss\U0000FFFF", "X\xDF\U0000FFFF".casefold());
test.assertEquals("xss\UFFFFFFFF", "X\xDF\UFFFFFFFF".casefold());
test.assertEquals("\xFF".bytes(), "\U000000FF".bytes().casefold());
test.assertEquals("\U000000FF", "\U000000FF".casefold());
test.assertEquals("\U0000FFFF", "\U0000FFFF".casefold());
test.assertEquals("\UFFFFFFFF", "\UFFFFFFFF".casefold());
test.assertEquals("\xDF\xFF".bytes(), "X\xDF\U000000FF".bytes().casefold(1, 9));
test.assertEquals("ss\U000000FF", "X\xDF\U000000FF".casefold(1, 9));
test.assertEquals("ss\U0000FFFF", "X\xDF\U0000FFFF".casefold(1, 9));
test.assertEquals("ss\UFFFFFFFF", "X\xDF\UFFFFFFFF".casefold(1, 9));
test.assertEquals("".bytes(), "\U000000FF".bytes().casefold(1, 9));
test.assertEquals("", "\U000000FF".casefold(1, 9));
test.assertEquals("", "\U0000FFFF".casefold(1, 9));
test.assertEquals("", "\UFFFFFFFF".casefold(1, 9));
test.assertEquals("".bytes(), "X\xDF\U000000FF".bytes().casefold(1, 1));
test.assertEquals("", "X\xDF\U000000FF".casefold(1, 1));
test.assertEquals("", "X\xDF\U0000FFFF".casefold(1, 1));
test.assertEquals("", "X\xDF\UFFFFFFFF".casefold(1, 1));
test.assertEquals("".bytes(), "\U000000FF".bytes().casefold(1, 1));
test.assertEquals("", "\U000000FF".casefold(1, 1));
test.assertEquals("", "\U0000FFFF".casefold(1, 1));
test.assertEquals("", "\UFFFFFFFF".casefold(1, 1));


/* asdigit */
for (local s, f, sx: {
	{ "7", "f", "7x" },
	{ "7".bytes(), "f".bytes(), "7x".bytes() },
}) {
	test.assertEquals(7, s.asdigit());
	test.assertEquals(7, s.asdigit(0));
	test.assertEquals(IndexError(seq: s, index: 1, length: 1), TRY(s.asdigit(1)));
	test.assertEquals(7, sx.asdigit(0));
	assert TRY(sx.asdigit()) is ValueError;
	assert TRY(f.asdigit()) is ValueError;
	assert TRY(f.asdigit(0)) is ValueError;
	test.assertEquals(9, f.asdigit(0, 9));

	test.assertEquals(7, s.asnumeric());
	test.assertEquals(7, s.asnumeric(0));
	test.assertEquals(IndexError(seq: s, index: 1, length: 1), TRY(s.asnumeric(1)));
	test.assertEquals(7, sx.asnumeric(0));
	assert TRY(sx.asnumeric()) is ValueError;
	assert TRY(f.asnumeric()) is ValueError;
	assert TRY(f.asnumeric(0)) is ValueError;
	test.assertEquals(9, f.asnumeric(0, 9));

	test.assertEquals(7, s.asxdigit());
	test.assertEquals(7, s.asxdigit(0));
	test.assertEquals(IndexError(seq: s, index: 1, length: 1), TRY(s.asxdigit(1)));
	test.assertEquals(7, sx.asxdigit(0));
	assert TRY(sx.asxdigit()) is ValueError;
	test.assertEquals(15, f.asxdigit());
	test.assertEquals(15, f.asxdigit(0));
	test.assertEquals(15, f.asxdigit(0, 9));
	test.assertEquals(9, sx.asxdigit(1, 9));
}

assert TRY("\u00B2".asdigit()) is ValueError;
assert TRY("\u00B2".asxdigit()) is ValueError;
test.assertEquals(2, "\u00B2".asnumeric());

